# ─────────────────────────────────────────────
# Database (Supabase) — Session mode pooler (port 5432)
# Get from: Supabase → Settings → Database → Connection pooling → Session mode
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-[region].pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# Supabase Client
# Get from: https://supabase.com → project → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# ─────────────────────────────────────────────
# AI Provider — Groq (Free tier)
# Get from: https://console.groq.com → API Keys
# ─────────────────────────────────────────────
GROQ_API_KEY=""

# ─────────────────────────────────────────────
# Background Jobs — Inngest
# Get from: https://app.inngest.com → project → Settings
# ─────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─────────────────────────────────────────────
# Scraper config
# ─────────────────────────────────────────────
# Secret để bảo vệ /api/scrape/trigger (tự đặt bất kỳ chuỗi nào)
CRON_SECRET="your-secret-here"
# GitHub token (optional) — tăng rate limit từ 60 lên 5000 req/hour
# Get from: github.com → Settings → Developer settings → Personal access tokens
# GITHUB_TOKEN=""

# ─────────────────────────────────────────────
# Future: Claude API (add when available)
# Get from: https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=""
